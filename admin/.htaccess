# PHPセッションによるアクセス制御
# このフォルダはPHPログイン認証で保護されています
Options -Indexes

# 直接アクセス禁止（PHPファイル以外）
<FilesMatch "^(?!.*\.php$)">
  Order Allow,Deny
  Allow from all
</FilesMatch>

# ============================================================
# パスワード設定（サーバー上でのみ設定してください）
# 以下の行のコメントを外し、実際のパスワードに変更してください：
# SetEnv GLORIA_ADMIN_PASSWORD あなたのパスワードをここに入力
# ============================================================
